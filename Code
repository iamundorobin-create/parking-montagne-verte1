<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Parking Montagne Verte – Colmar</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0e1a14;
      --surface: #162010;
      --card: #1c2b18;
      --accent: #6abf69;
      --accent2: #a8e6a3;
      --text: #e8f5e2;
      --muted: #7a9e74;
      --border: #2e4a28;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      overflow-x: hidden;
    }

    /* Animated background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 50% at 20% 20%, #2d4a2010 0%, transparent 60%),
        radial-gradient(ellipse 50% 60% at 80% 80%, #6abf6908 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    .wrapper {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 420px;
    }

    /* Header */
    .header {
      text-align: center;
      margin-bottom: 36px;
      animation: fadeDown 0.6s ease both;
    }

    .icon-pin {
      width: 56px;
      height: 56px;
      margin: 0 auto 16px;
      background: linear-gradient(135deg, var(--accent), #3d8b3d);
      border-radius: 50% 50% 50% 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      box-shadow: 0 8px 32px #6abf6940;
      transform: rotate(-15deg);
    }

    h1 {
      font-family: 'Syne', sans-serif;
      font-size: 1.75rem;
      font-weight: 800;
      line-height: 1.1;
      letter-spacing: -0.02em;
      color: var(--text);
    }

    h1 span {
      color: var(--accent);
    }

    .subtitle {
      margin-top: 8px;
      font-size: 0.88rem;
      color: var(--muted);
      font-weight: 300;
      letter-spacing: 0.03em;
    }

    /* Divider */
    .divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
      animation: fadeUp 0.6s 0.2s ease both;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .divider span {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--muted);
    }

    /* Cards */
    .cards {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .card {
      display: flex;
      align-items: center;
      gap: 18px;
      padding: 18px 20px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 16px;
      text-decoration: none;
      color: var(--text);
      cursor: pointer;
      transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
      animation: fadeUp 0.5s ease both;
      position: relative;
      overflow: hidden;
    }

    .card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, transparent 60%, #ffffff04);
      pointer-events: none;
    }

    .card:nth-child(1) { animation-delay: 0.3s; }
    .card:nth-child(2) { animation-delay: 0.4s; }
    .card:nth-child(3) { animation-delay: 0.5s; }

    .card:hover {
      transform: translateY(-3px);
      border-color: var(--accent);
      box-shadow: 0 12px 40px #6abf6920;
    }

    .card:active {
      transform: scale(0.97);
    }

    .logo-wrap {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 28px;
      box-shadow: 0 4px 16px #0006;
    }

    .logo-waze   { background: #00c1e9; }
    .logo-google { background: #fff; }
    .logo-apple  { background: #1c1c1e; border: 1px solid #3a3a3c; }

    .card-info {
      flex: 1;
    }

    .card-name {
      font-family: 'Syne', sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .card-desc {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .arrow {
      color: var(--muted);
      font-size: 1.1rem;
      transition: transform 0.18s ease, color 0.18s ease;
    }

    .card:hover .arrow {
      transform: translateX(4px);
      color: var(--accent);
    }

    /* Footer */
    .footer {
      text-align: center;
      margin-top: 32px;
      font-size: 0.72rem;
      color: var(--muted);
      letter-spacing: 0.04em;
      animation: fadeUp 0.6s 0.7s ease both;
      opacity: 0;
      animation-fill-mode: forwards;
    }

    .footer strong {
      color: var(--accent2);
      font-weight: 500;
    }

    /* Animations */
    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-20px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <div class="header">
      <div class="icon-pin">🌲</div>
      <h1>Parking <span>Montagne Verte</span></h1>
      <p class="subtitle">Colmar • Choisissez votre application GPS</p>
    </div>

    <div class="divider"><span>Ouvrir avec</span></div>

    <div class="cards">

      <!-- Waze -->
      <a class="card" href="https://waze.com/ul?ll=48.0763,7.3397&navigate=yes" target="_blank" rel="noopener">
        <div class="logo-wrap logo-waze">
          <svg width="30" height="30" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="24" cy="22" rx="18" ry="16" fill="white"/>
            <ellipse cx="17" cy="19" rx="2.5" ry="3" fill="#333"/>
            <ellipse cx="31" cy="19" rx="2.5" ry="3" fill="#333"/>
            <path d="M18 27 Q24 32 30 27" stroke="#333" stroke-width="2" fill="none" stroke-linecap="round"/>
            <circle cx="30" cy="37" r="4" fill="white" stroke="#333" stroke-width="2"/>
            <circle cx="18" cy="39" r="3" fill="white" stroke="#333" stroke-width="2"/>
          </svg>
        </div>
        <div class="card-info">
          <div class="card-name">Waze</div>
          <div class="card-desc">Trafic en temps réel · Communauté</div>
        </div>
        <span class="arrow">→</span>
      </a>

      <!-- Google Maps -->
      <a class="card" href="https://www.google.com/maps/dir/?api=1&destination=48.0763,7.3397&travelmode=driving" target="_blank" rel="noopener">
        <div class="logo-wrap logo-google">
          <svg width="30" height="30" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
            <path d="M24 4C15.16 4 8 11.16 8 20c0 13.5 16 28 16 28S40 33.5 40 20C40 11.16 32.84 4 24 4z" fill="#EA4335"/>
            <circle cx="24" cy="20" r="7" fill="white"/>
            <circle cx="24" cy="20" r="4" fill="#EA4335"/>
          </svg>
        </div>
        <div class="card-info">
          <div class="card-name">Google Maps</div>
          <div class="card-desc">Itinéraires détaillés · Street View</div>
        </div>
        <span class="arrow">→</span>
      </a>

      <!-- Apple Plans -->
      <a class="card" href="http://maps.apple.com/?daddr=48.0763,7.3397&dirflg=d" target="_blank" rel="noopener">
        <div class="logo-wrap logo-apple">
          <svg width="28" height="28" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="6" y="6" width="36" height="36" rx="8" fill="#1c6ef3"/>
            <path d="M24 10 L38 38 H10 Z" fill="white" opacity="0.15"/>
            <path d="M14 38 L24 14 L34 38" stroke="white" stroke-width="3" fill="none" stroke-linejoin="round"/>
            <line x1="17" y1="30" x2="31" y2="30" stroke="white" stroke-width="2.5"/>
            <circle cx="34" cy="16" r="4" fill="#ff3b30"/>
            <line x1="34" y1="10" x2="34" y2="14" stroke="white" stroke-width="2"/>
          </svg>
        </div>
        <div class="card-info">
          <div class="card-name">Apple Plans</div>
          <div class="card-desc">Intégré iOS · Carplay natif</div>
        </div>
        <span class="arrow">→</span>
      </a>

    </div>

    <div class="footer">
      <strong>Parking Montagne Verte</strong><br>
      Colmar, Haut-Rhin · Alsace
    </div>

  </div>
</body>
</html>